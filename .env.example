POSTGRES_USER=workflow
POSTGRES_PASSWORD=workflow
POSTGRES_DB=workflow

# Local PostgreSQL URL. On Render, set DATABASE_URL from Render Postgres internal connection string.
DATABASE_URL=postgresql://workflow:workflow@localhost:5432/workflow?schema=public

# Optional for future queue/cache work. The current MVP does not require Redis at runtime.
REDIS_URL=redis://localhost:6379

# Local API port. Render sets PORT automatically for web services.
API_PORT=3001
# PORT=3001

# Comma-separated browser origins allowed by the API. Leave unset for local/demo open CORS.
# CORS_ORIGIN=http://localhost:3000

# Public API URL consumed by Nuxt. On Render, use the API service public URL.
NUXT_PUBLIC_API_BASE_URL=http://localhost:3001
