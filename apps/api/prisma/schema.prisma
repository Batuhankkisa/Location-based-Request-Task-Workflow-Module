generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LocationType {
  ORGANIZATION
  FLOOR
  ROOM
  AREA
}

enum RequestChannel {
  QR_WEB
}

enum TaskStatus {
  NEW
  IN_PROGRESS
  DONE_WAITING_APPROVAL
  APPROVED
  REJECTED
}

enum QrScanStatus {
  RESOLVED
  INACTIVE
  TOKEN_NOT_FOUND
  REQUEST_CREATED
  REQUEST_FAILED
}

enum RequestMediaType {
  IMAGE
  AUDIO
}

model Location {
  id              String           @id @default(cuid())
  name            String
  code            String           @unique
  type            LocationType
  parentId        String?
  parent          Location?        @relation("LocationTree", fields: [parentId], references: [id], onDelete: SetNull)
  children        Location[]       @relation("LocationTree")
  qrCodes         QrCode[]
  visitorRequests VisitorRequest[]
  tasks           Task[]
  qrScanLogs      QrScanLog[]      @relation("QrScanLogLocation")
  createdAt       DateTime         @default(now())

  @@index([parentId])
}

model QrCode {
  id              String           @id @default(cuid())
  token           String           @unique
  label           String
  isActive        Boolean          @default(true)
  deactivatedAt   DateTime?
  lastScannedAt   DateTime?
  scanCount       Int              @default(0)
  imagePath       String?
  note            String?
  locationId      String
  location        Location         @relation(fields: [locationId], references: [id], onDelete: Restrict)
  visitorRequests VisitorRequest[]
  scanLogs        QrScanLog[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([locationId])
  @@index([isActive])
}

model VisitorRequest {
  id             String         @id @default(cuid())
  qrCodeId       String
  qrCode         QrCode         @relation(fields: [qrCodeId], references: [id], onDelete: Restrict)
  locationId     String
  location       Location       @relation(fields: [locationId], references: [id], onDelete: Restrict)
  requestText    String
  transcriptText String?
  audioFileUrl   String?
  channel        RequestChannel @default(QR_WEB)
  task           Task?
  scanLogs       QrScanLog[]
  media          RequestMedia[]
  createdAt      DateTime       @default(now())

  @@index([qrCodeId])
  @@index([locationId])
}

model RequestMedia {
  id           String           @id @default(cuid())
  requestId    String
  request      VisitorRequest   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  type         RequestMediaType
  fileUrl      String
  storageKey   String
  mimeType     String
  fileSize     Int
  originalName String?
  createdAt    DateTime         @default(now())

  @@index([requestId])
  @@index([type])
}

model Task {
  id          String        @id @default(cuid())
  requestId   String        @unique
  request     VisitorRequest @relation(fields: [requestId], references: [id], onDelete: Restrict)
  locationId  String
  location    Location      @relation(fields: [locationId], references: [id], onDelete: Restrict)
  status      TaskStatus    @default(NEW)
  assignedTo  String?
  completedBy String?
  approvedBy  String?
  createdAt   DateTime      @default(now())
  completedAt DateTime?
  approvedAt  DateTime?
  history     TaskHistory[]
  scanLogs    QrScanLog[]

  @@index([locationId])
  @@index([status])
}

model TaskHistory {
  id         String      @id @default(cuid())
  taskId     String
  task       Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fromStatus TaskStatus?
  toStatus   TaskStatus
  note       String?
  changedBy  String?
  createdAt  DateTime    @default(now())

  @@index([taskId])
}

model QrScanLog {
  id                 String          @id @default(cuid())
  qrCodeId           String?
  qrCode             QrCode?         @relation(fields: [qrCodeId], references: [id], onDelete: SetNull)
  tokenSnapshot      String
  scannedAt          DateTime        @default(now())
  ip                 String?
  userAgent          String?
  resolvedLocationId String?
  resolvedLocation   Location?       @relation("QrScanLogLocation", fields: [resolvedLocationId], references: [id], onDelete: SetNull)
  status             QrScanStatus
  requestId          String?
  request            VisitorRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  createdTaskId      String?
  createdTask        Task?           @relation(fields: [createdTaskId], references: [id], onDelete: SetNull)
  errorMessage       String?

  @@index([qrCodeId])
  @@index([scannedAt])
  @@index([status])
  @@index([requestId])
  @@index([resolvedLocationId])
}
