{
  "name": "@lbrtw/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @lbrtw/shared build && dotenv -e ../../.env.example -e ../../.env -- nest start --watch",
    "build": "pnpm --filter @lbrtw/shared build && prisma generate && tsc -p tsconfig.build.json",
    "start": "dotenv -e ../../.env.example -e ../../.env -- node dist/main.js",
    "start:prod": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "dotenv -e ../../.env.example -e ../../.env -- prisma migrate dev",
    "prisma:deploy": "dotenv -e ../../.env.example -e ../../.env -- prisma migrate deploy",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "dotenv -e ../../.env.example -e ../../.env -- prisma db seed"
  },
  "dependencies": {
    "@lbrtw/shared": "workspace:*",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^6.2.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/passport-jwt": "^4.0.1",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/schematics": "^10.2.3",
    "@types/node": "^22.10.5",
    "dotenv-cli": "^7.4.4",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
