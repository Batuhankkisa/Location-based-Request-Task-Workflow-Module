{
  "name": "@lbrtw/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @lbrtw/shared build && dotenv -e ../../.env.example -e ../../.env -o -- nuxi dev --no-fork --host 0.0.0.0 --port 3000",
    "build": "pnpm --filter @lbrtw/shared build && dotenv -e ../../.env.example -e ../../.env -o -- nuxi build",
    "preview": "dotenv -e ../../.env.example -e ../../.env -o -- nuxi preview --host 0.0.0.0 --port 3000"
  },
  "dependencies": {
    "@lbrtw/shared": "workspace:*",
    "nuxt": "3.15.1"
  },
  "devDependencies": {
    "dotenv-cli": "7.4.4",
    "typescript": "5.7.3"
  }
}
