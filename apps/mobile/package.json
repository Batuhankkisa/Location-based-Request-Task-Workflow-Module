{
  "name": "@lbrtw/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "pnpm --filter @lbrtw/shared build && expo start --clear",
    "dev:tunnel": "pnpm --filter @lbrtw/shared build && expo start --clear --tunnel",
    "web": "pnpm --filter @lbrtw/shared build && expo start --clear --web",
    "android": "pnpm --filter @lbrtw/shared build && expo start --android",
    "ios": "pnpm --filter @lbrtw/shared build && expo start --ios",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^14.0.4",
    "@lbrtw/shared": "workspace:*",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.3.12",
    "axios": "^1.9.0",
    "expo": "^54.0.0",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.0",
    "typescript": "5.7.3"
  }
